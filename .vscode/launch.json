{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Run nodemon",
      "runtimeExecutable": "nodemon",
      "runtimeArgs": [
        "-r",
        "dotenv/config",
        "--experimental-json-modules",
        "src/server.js"
      ],
      "cwd": "${workspaceFolder}",
      "console": "internalConsole",
      "internalConsoleOptions": "neverOpen",
      "restart": true
    }
  ]
}
